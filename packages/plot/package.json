{
  "name": "@pennsieve-viz/plot",
  "version": "0.1.0",
  "description": "Plotly-based visualization components for Pennsieve",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "@pennsieve-viz/core": "^0.2.0",
    "element-plus": "^2.3.0",
    "plotly.js": "^2.35.0",
    "plotly.js-dist": "^2.35.0",
    "pinia": "^2.0.0 || ^3.0.0",
    "vue": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "plotly.js": {
      "optional": true
    },
    "plotly.js-dist": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pennsieve-viz/core": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vue": "^3.5.17"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pennsieve/pennsieve-visualization.git",
    "directory": "packages/plot"
  }
}
